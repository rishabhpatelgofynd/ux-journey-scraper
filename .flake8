[flake8]
max-line-length = 100
max-complexity = 10
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache

# E501: line too long (handled by black)
# W503: line break before binary operator (conflicts with black)
# E203: whitespace before ':' (conflicts with black)
ignore = E501, W503, E203

# Per-file ignores
per-file-ignores =
    __init__.py: F401
    tests/*: F401, F811
